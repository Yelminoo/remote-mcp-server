{
  "name": "trello-mcp-server",
  "version": "1.0.0",
  "description": "Trello MCP server + Universal MCP Host — connect any LLM to any MCP server",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "umcp": "dist/host/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch & sleep 2 && node dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "host": "node dist/host/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "axios": "^1.7.0",
    "commander": "^12.1.0",
    "express": "^4.18.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
